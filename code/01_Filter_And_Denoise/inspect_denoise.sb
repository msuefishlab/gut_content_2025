#!/bin/bash --login

########## Define Resources Needed with SBATCH Lines ##########

#SBATCH --time=04:00:00             # limit of wall clock time - how long the job will run (same as -t)
#SBATCH --ntasks=1                  # number of tasks - how many tasks (nodes) that you require (same as -n)
#SBATCH --cpus-per-task=2          # number of CPUs (or cores) per task (same as -c)
#SBATCH --mem=12g                   # memory required per node - amount of memory (in bytes)
#SBATCH -J prep_qiime_data		  # the name of the job
#SBATCH -A data-machine
########## Command Lines to Run ##########

root="$(git rev-parse --show-toplevel)"
source ${root}/"gut_contents.env"

output_data=${root}/output_data

mkdir -p ${output_data}

singularity exec --bind $TMPDIR:/home/qiime2/q2cli $qiime_image qiime metadata tabulate \
--m-input-file ${output_data}/${run}_${primerset}_denoised/denoising_stats.qza \
--o-visualization ${output_data}/${run}_${primerset}_denoised/denoising_stats.qzv 


singularity exec --bind $TMPDIR:/home/qiime2/q2cli $qiime_image qiime feature-table tabulate-seqs \
--i-data ${output_data}/${run}_${primerset}_denoised/representative_sequences.qza \
--o-visualization ${output_data}/${run}_${primerset}_denoised/representative_sequences.qzv 

singularity exec --bind $TMPDIR:/home/qiime2/q2cli $qiime_image qiime feature-table summarize \
--i-table ${output_data}/${run}_${primerset}_denoised/table.qza \
--o-visualization ${output_data}/${run}_${primerset}_denoised/table.qzv 