Bootstrap: docker
From: quay.io/qiime2/core:2019.10

%post
    echo "Copying q2cli directory..."
    mkdir -p /home/qiime/q2cli
    cp -r /opt/conda/envs/qiime2-amplicon-2024.10/var/q2cli /home/qiime/q2cli
    echo "Modification complete!"

%labels
    Maintainer "Jason Gallant <jgallant@msu.edu>"
    Version "2019.10"
